{
  "name": "cowork-by-ihy",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "TZ=Asia/Yangon NODE_OPTIONS='--require ./scripts/register-localstorage.cjs' next dev",
    "build": "TZ=Asia/Yangon prisma generate && prisma db push && TZ=Asia/Yangon NODE_OPTIONS='--require ./scripts/register-localstorage.cjs' next build",
    "start": "TZ=Asia/Yangon NODE_OPTIONS='--require ./scripts/register-localstorage.cjs' next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.7.0",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "0.468.0",
    "next": "15.3.8",
    "pg": "^8.20.0",
    "prisma": "6.7.0",
    "react": "19.0.1",
    "react-dom": "19.0.1",
    "zod": "3.24.3"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "tsx": "4.19.4",
    "typescript": "5.8.3"
  }
}
